  "attack_patterns": [
    {
      "id": "usb_exfil_financial_001",
      "name": "USB Exfiltration - Financial Documents",
      "category": "data_exfiltration",
      "subcategory": "physical_medium",
      "mitre_technique": "T1052.001",
      "severity": "high",
      "description": "Employee copies sensitive financial documents to USB drive",
      "sequence": [
        {
          "step": 1,
          "event_type": "file_access",
          "event_category": "file",
          "action": "read",
          "resource_patterns": [
            "C:\\Finance\\Q4_Budget.xlsx",
            "C:\\Finance\\Salaries_2024.xlsx",
            "C:\\Accounting\\Revenue_Report.xlsx"
          ],
          "time_offset_minutes": [-15, -10],
          "metadata": {
            "sensitivity_level": 2,
            "file_size_bytes": [2000000, 8000000]
          }
        },
        {
          "step": 2,
          "event_type": "device_connect",
          "event_category": "device",
          "action": "connect",
          "resource_patterns": [
            "USB_DEVICE_VID_0781_PID_5567",
            "USB_DEVICE_VID_058F_PID_6387",
            "USB_DEVICE_VID_090C_PID_1000"
          ],
          "time_offset_minutes": [-5, -2],
          "metadata": {
            "device_type": "usb_storage"
          }
        },
        {
          "step": 3,
          "event_type": "file_access",
          "event_category": "file",
          "action": "write",
          "resource_patterns": [
            "E:\\Financial_Data.xlsx",
            "F:\\Backup_Files.zip",
            "E:\\Documents\\Export.xlsx"
          ],
          "time_offset_minutes": [0, 0],
          "metadata": {
            "is_usb": true,
            "sensitivity_level": 2,
            "file_size_bytes": [5000000, 20000000]
          }
        }
      ]
    },
