# ============================================
# Cyber-Data Genesis — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys

# Google Gemini API Key (for ADK agents)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (optional fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Daytona API Key (for sandboxed code execution)
DAYTONA_API_KEY=your_daytona_api_key_here
DAYTONA_SERVER_URL=https://app.daytona.io

# MCP Server Ports
MCP_LOG_READER_PORT=8001
MCP_WEB_SCRAPER_PORT=8002
MCP_PYTHON_EXECUTOR_PORT=8003
MCP_ATTACK_INJECTOR_PORT=8004
MCP_SEQUENTIAL_THINKING_PORT=8005
